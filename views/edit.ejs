<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Student | Management System</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at top left, #1e293b, #0f172a);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #f8fafc;
            margin: 0;
            padding: 20px;
        }

        .glass-panel {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 40px;
            width: 100%;
            max-width: 550px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        h2 {
            font-weight: 600;
            color: #10b981; /* Emerald Green */
            text-align: center;
            margin-bottom: 30px;
            letter-spacing: -0.5px;
        }

        .form-label {
            font-size: 0.85rem;
            font-weight: 500;
            color: #94a3b8;
            margin-bottom: 8px;
        }

        .form-control {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid #334155;
            border-radius: 12px;
            color: white !important;
            padding: 12px 16px;
            transition: all 0.2s ease;
        }

        .form-control:focus {
            background: rgba(15, 23, 42, 0.8);
            border-color: #10b981;
            box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
            outline: none;
        }

        .btn-update {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 600;
            color: white;
            width: 100%;
            margin-top: 20px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .btn-update:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.4);
            color: white;
        }

        .btn-back {
            background: transparent;
            border: 1px solid #334155;
            color: #94a3b8;
            border-radius: 12px;
            width: 100%;
            padding: 12px;
            margin-top: 12px;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            transition: all 0.2s;
        }

        .btn-back:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #f8fafc;
            border-color: #475569;
        }
    </style>
</head>
<body>

<div class="glass-panel">
    <h2><i class="fas fa-user-edit me-2"></i>Edit Student</h2>
    
    <form action="/update/<%= student.id %>" method="POST">
        <div class="row">
            <div class="col-md-12 mb-3">
                <label class="form-label">Student ID</label>
                <input type="text" name="student_id" value="<%= student.student_id %>" class="form-control" required>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Full Name</label>
            <input type="text" name="full_name" value="<%= student.full_name %>" class="form-control" required>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Course</label>
                <input type="text" name="course" value="<%= student.course %>" class="form-control" required>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Year Level</label>
                <input type="text" name="year_level" value="<%= student.year_level %>" class="form-control" required>
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label">Email Address</label>
            <input type="email" name="email_address" value="<%= student.email_address %>" class="form-control" required>
        </div>

        <button type="submit" class="btn btn-update">
            <i class="fas fa-save me-2"></i>Update Record
        </button>
        
        <a href="/" class="btn btn-back">
            <i class="fas fa-arrow-left me-1"></i> Back to Directory
        </a>
    </form>
</div>

</body>
</html>
