<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Directory | Pro System</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at top right, #1e293b, #0f172a);
            min-height: 100vh;
            color: #f8fafc;
            padding: 40px 0;
        }

        .glass-card {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(12px);
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            padding: 30px;
        }

        /* Table Design */
        .table {
            color: #f8fafc;
            border-color: rgba(255, 255, 255, 0.05);
        }

        .table thead {
            background-color: rgba(15, 23, 42, 0.8);
            color: #10b981; /* Emerald */
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1.5px;
        }

        .table-hover tbody tr:hover {
            background-color: rgba(16, 185, 129, 0.05);
            color: #fff;
        }

        /* UI Elements */
        .badge-year {
            background: rgba(16, 185, 129, 0.2);
            color: #10b981;
            border: 1px solid rgba(16, 185, 129, 0.3);
            padding: 5px 14px;
            border-radius: 50px;
            font-size: 0.8rem;
        }

        .btn-register {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            border: none;
            font-weight: 600;
            border-radius: 12px;
            transition: all 0.3s;
        }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.4);
            color: white;
        }

        /* DataTables Customization */
        .dataTables_wrapper .dataTables_length, 
        .dataTables_wrapper .dataTables_filter, 
        .dataTables_wrapper .dataTables_info, 
        .dataTables_wrapper .dataTables_paginate {
            color: #94a3b8 !important;
            margin-top: 15px;
        }

        .dataTables_wrapper .dataTables_filter input {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid #334155;
            border-radius: 8px;
            color: white;
            padding: 5px 15px;
        }

        .page-link {
            background-color: rgba(30, 41, 59, 0.5);
            border-color: #334155;
            color: #94a3b8;
        }

        .active > .page-link {
            background-color: #10b981 !important;
            border-color: #10b981 !important;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="glass-card">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h2 class="fw-bold mb-0 text-white">
                    <i class="fas fa-database me-2 text-emerald" style="color: #10b981;"></i>Student Directory
                </h2>
                <p class="text-muted small mb-0">Academic Information Management System</p>
            </div>
            <a href="/add" class="btn btn-register btn-lg px-4 text-white">
                <i class="fas fa-plus-circle me-2"></i>Register New
            </a>
        </div>

        <div class="table-responsive">
            <table id="studentTable" class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>ID Number</th>
                        <th>Student Name</th>
                        <th>Course</th>
                        <th>Level</th>
                        <th>Email Address</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% students.forEach(student => { %>
                        <tr>
                            <td class="fw-bold" style="color: #10b981;"><%= student.student_id %></td>
                            <td><%= student.full_name %></td>
                            <td><%= student.course %></td>
                            <td><span class="badge-year"><%= student.year_level %></span></td>
                            <td class="text-muted small"><%= student.email_address %></td>
                            <td class="text-center">
                                <div class="btn-group">
                                    <a href="/edit/<%= student.id %>" class="btn btn-outline-info btn-sm me-2" style="border-radius: 8px;" title="Edit">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                    <button onclick="confirmDelete('<%= student.id %>')" class="btn btn-outline-danger btn-sm" style="border-radius: 8px;" title="Delete">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    $(document).ready(function() {
        $('#studentTable').DataTable({
            "pageLength": 5,
            "lengthMenu": [5, 10, 25],
            "language": {
                "search": "",
                "searchPlaceholder": "Search directory..."
            }
        });
    });

    function confirmDelete(id) {
        Swal.fire({
            title: 'Are you sure?',
            text: "This record will be permanently removed from the database.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#10b981',
            cancelButtonColor: '#ef4444',
            confirmButtonText: 'Yes, delete it!',
            background: '#1e293b',
            color: '#f8fafc'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/delete/' + id;
            }
        })
    }
</script>

</body>
</html>
